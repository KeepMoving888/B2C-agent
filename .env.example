# ========== 服务端口 ==========
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8080

# ========== vLLM 推理服务 ==========
# vLLM OpenAI 兼容接口地址；留空则后端自动回退至规则引擎模式
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen2.5-7B-Instruct
# 推理参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TOP_P=0.9

# ========== LLM Provider 适配层（OpenAI 兼容接口） ==========
# 选择 LLM 后端: vllm / openai / deepseek / qwen / custom
# - vllm:     使用上面的 VLLM_* 配置（默认，本地 vLLM 服务）
# - openai:   使用 OpenAI 官方 API
# - deepseek: 使用 DeepSeek API
# - qwen:     使用阿里云通义千问 DashScope OpenAI 兼容模式
# - custom:   任意 OpenAI 兼容端点，复用 OPENAI_* 配置（base_url/api_key/model）
# 不部署 vLLM 时，配置任一云服务商 API Key 并切换 LLM_PROVIDER 即可接入真实 LLM
LLM_PROVIDER=vllm
# LLM 请求超时（秒），用于探测与实际调用
LLM_REQUEST_TIMEOUT=15

# --- OpenAI 官方 ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- 阿里云通义千问（DashScope OpenAI 兼容模式） ---
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ========== Milvus 向量库 ==========
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=cs_knowledge_base
# 向量维度（与 embedding 模型一致）
EMBEDDING_DIM=1024
# Embedding 模型（本地 HuggingFace 模型，离线可用）
# Embedding 模型：BGE-M3 多语言嵌入，原生跨语言语义对齐（dim=1024）
EMBEDDING_MODEL=BAAI/bge-m3

# ========== 知识库 ==========
# 是否在启动时自动构建索引（首次启动建议开启）
AUTO_BUILD_INDEX=true
# 重排序模型（Cross-Encoder）
RERANKER_MODEL=BAAI/bge-reranker-large

# ========== 多语言与跨语言检索对齐 ==========
SUPPORTED_LANGUAGES=en,ja,de,es,fr,it,pt,zh
DEFAULT_AGENT_LANG=zh
# 跨语言对齐枢轴语言：多语言 query 统一映射到该语言语义空间检索
CROSS_LINGUAL_PIVOT_LANG=zh
# 高频语言语料分区：对这些语言单独构建镜像分区
LANGUAGE_PARTITIONS=en,ja,de
# 是否启用语言分区检索
RAG_USE_PARTITION=true

# ========== 路由与长会话 ==========
# 双层路由置信度阈值：意图置信度低于该值触发人工转接兜底
INTENT_CONFIDENCE_THRESHOLD=0.7
# 滑动窗口大小：长会话上下文聚焦保留的最近轮数
CONTEXT_WINDOW_SIZE=6

# ========== 业务参数 ==========
# 情感阈值：不满情绪超过该值自动转人工
HUMAN_HANDOFF_SENTIMENT_THRESHOLD=75
# 最大对话轮数（超过后建议转人工）
MAX_DIALOGUE_TURNS=20

# ===== CORS 安全配置 =====
# 允许的前端域名（逗号分隔），生产环境严禁使用通配符 *
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ===== 多平台消息接入层（Kafka） =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CUSTOMER_MSG=customer-messages
KAFKA_TOPIC_AGENT_REPLY=agent-replies
KAFKA_TOPIC_HANDOFF=human-handoff
KAFKA_CONSUMER_GROUP=cs-agent-group

# ===== Elasticsearch =====
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_KNOWLEDGE=cs_knowledge_base
ES_INDEX_CONVERSATIONS=cs_conversations

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cs_platform
POSTGRES_USER=cs_admin
POSTGRES_PASSWORD=

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Celery =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== Jaeger 全链路追踪 =====
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SERVICE_NAME=cs-agent-platform

# ===== 模型微调与偏好对齐 =====
FINETUNE_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
FINETUNE_METHOD=qlora_4bit
DPO_ENABLED=true
DPO_DATASET_SIZE=2000
QUANTIZATION_METHOD=awq_4bit

# ===== vLLM 推理优化 =====
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=4096
