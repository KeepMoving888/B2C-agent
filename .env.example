# API 密钥
QWEN_API_KEY=your_qwen_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 向量数据库配置
VECTOR_DB_PROVIDER=chromadb  # 可选: chromadb, pinecone, milvus, faiss
PINECONE_API_KEY=your_pinecone_api_key_here
MILVUS_URI=your_milvus_uri_here

# 应用配置
FLASK_ENV=development
FLASK_APP=src/app.py

# 性能配置
LLM_CACHE_ENABLED=true
RAG_CACHE_ENABLED=true
HTTP_TIMEOUT=15

# 多平台配置
DEFAULT_PLATFORM=amazon
SUPPORTED_PLATFORMS=amazon,shopify,website

# 多语言配置
DEFAULT_LANGUAGE=zh
SUPPORTED_LANGUAGES=zh,en,es,de,fr,ja,th,vi